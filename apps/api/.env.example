NOTIFICATION_EMAIL_WEBHOOK_URL=
NOTIFICATION_PUSH_WEBHOOK_URL=
EXPO_ACCESS_TOKEN=
NOTIFICATION_MAX_ATTEMPTS=3
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=onboarding@resend.dev
NOTIFICATION_WORKER_POLL_SECONDS=30
NOTIFICATION_WORKER_BATCH_SIZE=25
NOTIFICATION_SENT_RETENTION_DAYS=14
NOTIFICATION_FAILED_RETENTION_DAYS=30
NOTIFICATION_MAINTENANCE_POLL_SECONDS=21600
LISTING_MEDIA_BUCKET=listing-media
