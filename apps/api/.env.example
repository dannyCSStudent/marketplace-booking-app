SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Required if you want the backend to serve public listing/seller reads without a user session.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SCHEMA=public
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NOTIFICATION_EMAIL_PROVIDER=log
NOTIFICATION_PUSH_PROVIDER=log
# Optional when using webhook delivery providers.
NOTIFICATION_EMAIL_WEBHOOK_URL=
NOTIFICATION_PUSH_WEBHOOK_URL=
NOTIFICATION_MAX_ATTEMPTS=3
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=onboarding@resend.dev
